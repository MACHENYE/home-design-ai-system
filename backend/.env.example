AI_PROVIDER=auto

NANOBANANA_API_KEY=replace_me
# NanoBanana API base URL. Adjust if the docs change.
NANOBANANA_BASE_URL=https://api.nanobananaapi.ai/api/v1/nanobanana

# Public base URL used to construct the callback URL sent to NanoBanana.
# Example (dev): https://xxxx.ngrok-free.app
# Example (prod): https://your-domain.com
PUBLIC_BASE_URL=http://localhost:8000

# SQLite file for task tracking (relative to backend/ when running from there).
TASKS_DB_PATH=./tasks.db

# Uploaded design/reference/mask images are saved here and exposed at /uploads.
UPLOADS_DIR=./uploads
FRONTEND_DIR=../frontend
MAX_UPLOAD_MB=12
