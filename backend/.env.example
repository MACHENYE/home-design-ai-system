NANOBANANA_API_KEY=replace_me
# NanoBanana API base URL. Adjust if the docs change.
NANOBANANA_BASE_URL=https://api.nanobananaapi.ai/api/v1/nanobanana

# Public base URL used to construct the callback URL sent to NanoBanana.
# Example (dev): https://xxxx.ngrok-free.app
# Example (prod): https://your-domain.com
PUBLIC_BASE_URL=http://localhost:8000

# SQLite file for task tracking (relative to backend/ when running from there).
TASKS_DB_PATH=./tasks.db

# Uploaded design/reference/mask images are saved here and exposed at /uploads.
UPLOADS_DIR=./uploads
FRONTEND_DIR=../frontend
MAX_UPLOAD_MB=12

# Optional: upload local files to a public server through SFTP.
# Keep this false unless your server has an /uploads URL exposed by Nginx.
REMOTE_UPLOAD_ENABLED=false
REMOTE_UPLOAD_HOST=your-server-ip
REMOTE_UPLOAD_PORT=22
REMOTE_UPLOAD_USER=root
# Use either password or a private key path. Prefer key auth for real use.
REMOTE_UPLOAD_PASSWORD=
REMOTE_UPLOAD_KEY_PATH=
REMOTE_UPLOAD_DIR=/home/home-design/uploads
REMOTE_PUBLIC_BASE_URL=http://your-server-ip/uploads
REMOTE_UPLOAD_TIMEOUT_S=20

# Optional: use Alibaba Cloud Model Studio (Bailian) Qwen-VL to recommend
# 4 style templates from uploaded images.
# If disabled or BAILIAN_API_KEY/DASHSCOPE_API_KEY is empty, the frontend keeps the initial 4 templates.
VISION_RECOMMENDATION_ENABLED=false
BAILIAN_API_KEY=
# You can also use DASHSCOPE_API_KEY instead of BAILIAN_API_KEY.
DASHSCOPE_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_VISION_MODEL=qwen3-vl-plus
BAILIAN_TIMEOUT_S=35
